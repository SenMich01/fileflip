# SPA fallback routing - serve index.html for all routes except static assets
/* /index.html 200

# Ensure static assets are served correctly
/assets/* /assets/:splat 200
/favicon.ico /favicon.ico 200
/static/* /static/:splat 200
/build/* /build/:splat 200
/dist/* /dist/:splat 200
/public/* /public/:splat 200

# API routes should be handled by the server
/api/* /api/:splat 200
